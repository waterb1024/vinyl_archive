<!DOCTYPE html>
<html lang="en">
<head>
  <% const pageTitle = 'Add Record'; %>
  <%- include('partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container narrow">
    <p class="muted small back"><a href="/">← Back</a></p>
    <h1 class="form-title">Add a Record</h1>

    <% if (errors.length) { %>
      <ul class="errors">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    <% } %>

    <% if (discogsEnabled) { %>
      <section class="discogs">
        <p class="eyebrow">Search Discogs</p>
        <div class="discogs-search">
          <input type="search" id="discogs-q" placeholder="Album, artist, barcode…" autocomplete="off" />
          <span class="discogs-status" id="discogs-status"></span>
        </div>
        <ul class="discogs-results" id="discogs-results" hidden></ul>
      </section>
    <% } %>

    <form action="/albums" method="post" enctype="multipart/form-data" class="form" id="album-form">
      <label>
        <span>Title <em>*</em></span>
        <input type="text" name="title" required value="<%= values.title || '' %>" />
      </label>
      <label>
        <span>Artist <em>*</em></span>
        <input type="text" name="artist" required value="<%= values.artist || '' %>" />
      </label>
      <div class="row">
        <label>
          <span>Year</span>
          <input type="number" name="year" min="1900" max="2100" value="<%= values.year || '' %>" />
        </label>
        <label>
          <span>Genre</span>
          <input type="text" name="genre" value="<%= values.genre || '' %>" />
        </label>
      </div>
      <label>
        <span>Label</span>
        <input type="text" name="label" value="<%= values.label || '' %>" />
      </label>
      <label>
        <span>Notes</span>
        <textarea name="notes" rows="4"><%= values.notes || '' %></textarea>
      </label>

      <div class="row">
        <label>
          <span>Purchase price <em class="muted">(KRW)</em></span>
          <input type="text" inputmode="numeric" name="purchase_price" placeholder="e.g. 32000" value="<%= values.purchase_price || '' %>" />
        </label>
        <label>
          <span>Purchase date</span>
          <input type="date" name="purchase_date" value="<%= values.purchase_date || '' %>" />
        </label>
      </div>

      <input type="hidden" name="cover_url" id="cover_url" value="" />
      <input type="hidden" name="discogs_release_id" id="discogs_release_id" value="<%= values.discogs_release_id || '' %>" />
      <div class="cover-preview" id="cover-preview" hidden>
        <img id="cover-preview-img" alt="" />
        <div>
          <p class="muted small" style="margin:0">Cover from Discogs</p>
          <button type="button" class="btn btn-ghost btn-tiny" id="cover-clear">Remove</button>
        </div>
      </div>

      <label class="file">
        <span>Cover image <em class="muted">(optional, max 5MB — overrides Discogs cover)</em></span>
        <input type="file" name="cover" accept="image/*" />
      </label>

      <div class="actions">
        <button type="submit" class="btn btn-primary">Save Record</button>
        <a href="/" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </main>

  <%- include('partials/footer') %>

  <% if (discogsEnabled) { %>
  <script src="/discogs-search.js" defer></script>
  <% } %>
</body>
</html>
