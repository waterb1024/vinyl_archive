<!DOCTYPE html>
<html lang="en">
<head>
  <% const pageTitle = album.title; %>
  <%- include('partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container detail">
    <p class="muted small back"><a href="/">← Back to Collection</a></p>

    <article class="detail-grid">
      <div class="detail-cover">
        <img src="/albums/<%= album.id %>/cover?v=<%= album.cover_version || 1 %>" alt="<%= album.title %> cover" />
      </div>

      <div class="detail-info">
        <p class="eyebrow">
          <% if (album.year) { %><%= album.year %> · <% } %><%= album.genre || 'Unfiled' %>
          <% if (album.status === 'wishlist') { %>
            <span class="status-badge status-wishlist">Wishlist</span>
          <% } %>
        </p>
        <h1 class="detail-title"><%= album.title %></h1>
        <p class="detail-artist"><%= album.artist %></p>

        <dl class="facts">
          <% if (album.label) { %>
            <div><dt>Label</dt><dd><%= album.label %></dd></div>
          <% } %>
          <% if (album.year) { %>
            <div><dt>Released</dt><dd><%= album.year %></dd></div>
          <% } %>
          <% if (album.genre) { %>
            <div><dt>Genre</dt><dd><%= album.genre %></dd></div>
          <% } %>
        </dl>

        <% if (album.status === 'wishlist') { %>
          <% const krwFmt = (n) => n == null ? null : '₩' + Number(n).toLocaleString('ko-KR'); %>
          <% const target = album.target_price_krw ? Number(album.target_price_krw) : null; %>
          <% const market = album.last_price_krw != null ? Number(album.last_price_krw) : null; %>
          <% const hitTarget = target != null && market != null && market <= target; %>
          <% if (market != null) { %>
            <div class="price-block">
              <h2>Market price</h2>
              <div class="price-row">
                <div class="price-cell">
                  <span class="price-label">Market high <em class="muted">(Discogs)</em></span>
                  <span class="price-value"><%= krwFmt(market) %></span>
                  <% if (album.last_price_usd) { %>
                    <span class="price-sub muted small">$<%= Number(album.last_price_usd).toFixed(2) %></span>
                  <% } %>
                </div>
              </div>
              <% if (target != null) { %>
                <% if (hitTarget) { %>
                  <p class="target-alert">🎯 원하시던 <%= krwFmt(target) %>에 도달했어요. 지금이 살 타이밍!</p>
                <% } else {
                     const diff = market - target;
                     const dropPct = market > 0 ? (diff / market) * 100 : 0;
                %>
                  <p class="target-alert target-pending">아직 원하시는 <strong><%= krwFmt(target) %></strong>에 도달하려면 <strong><%= krwFmt(diff) %>(<%= dropPct.toFixed(1) %>%)</strong>만큼 남았어요.</p>
                <% } %>
              <% } %>
              <% if (album.discogs_release_id) { %>
                <div class="chart-section">
                  <p class="eyebrow">Monthly highs</p>
                  <div id="price-chart" data-album-id="<%= album.id %>"></div>
                  <p class="chart-status muted small" id="price-chart-status">Loading…</p>
                </div>
              <% } %>
            </div>
          <% } else if (target != null) { %>
            <div class="price-block">
              <h2>Target set</h2>
              <p class="price-value"><%= krwFmt(target) %></p>
              <p class="muted small">시세가 수집되면 목표가 도달 여부를 알려드릴게요.</p>
            </div>
          <% } %>
          <form class="convert-block" action="/albums/<%= album.id %>/convert" method="post">
            <h2>소장으로 옮기기</h2>
            <p class="muted small">이 음반을 구매하셨다면 가격과 날짜를 기록해주세요.</p>
            <div class="row">
              <label>
                <span>Purchase price <em class="muted">(KRW)</em></span>
                <input type="text" inputmode="numeric" name="purchase_price" placeholder="e.g. 32000" required />
              </label>
              <label>
                <span>Purchase date</span>
                <input type="date" name="purchase_date" />
              </label>
            </div>
            <button type="submit" class="btn btn-primary">소장으로 전환</button>
          </form>
        <% } else if (album.purchase_price || album.last_price_krw) {
             const krwFmt = (n) => n == null ? null : '₩' + Number(n).toLocaleString('ko-KR');
             const purchase = album.purchase_price ? Number(album.purchase_price) : null;
             const market = album.last_price_krw ? Number(album.last_price_krw) : null;
             const diff = (purchase != null && market != null) ? market - purchase : null;
        %>
          <div class="price-block">
            <h2>Price</h2>
            <div class="price-row">
              <% if (purchase != null) { %>
                <div class="price-cell">
                  <span class="price-label">Purchased</span>
                  <span class="price-value"><%= krwFmt(purchase) %></span>
                </div>
              <% } %>
              <% if (market != null) { %>
                <div class="price-cell">
                  <span class="price-label">Market high <em class="muted">(Discogs)</em></span>
                  <span class="price-value"><%= krwFmt(market) %></span>
                  <% if (album.last_price_usd) { %>
                    <span class="price-sub muted small">$<%= Number(album.last_price_usd).toFixed(2) %></span>
                  <% } %>
                </div>
              <% } else if (album.discogs_release_id) { %>
                <div class="price-cell"><span class="muted small">No marketplace data yet.</span></div>
              <% } %>
            </div>
            <% if (diff != null) {
                 const sign = diff > 0 ? 'up' : (diff < 0 ? 'down' : 'flat');
                 const word = diff > 0 ? '올랐네요' : (diff < 0 ? '내렸네요' : '동일해요');
                 const pct = purchase > 0 ? (diff / purchase) * 100 : null;
                 const pctStr = pct != null
                   ? (pct > 0 ? '+' : '') + (Math.abs(pct) >= 100 ? Math.round(pct) : pct.toFixed(1)) + '%'
                   : null;
            %>
              <p class="price-diff price-diff-<%= sign %>">
                구매가보다 <strong><%= krwFmt(Math.abs(diff)) %></strong><% if (pctStr) { %> <span class="price-pct">(<%= pctStr %>)</span><% } %> <%= word %>
              </p>
            <% } %>

            <% if (album.discogs_release_id) { %>
              <div class="chart-section">
                <p class="eyebrow">Monthly highs</p>
                <div id="price-chart" data-album-id="<%= album.id %>"></div>
                <p class="chart-status muted small" id="price-chart-status">Loading…</p>
              </div>
            <% } %>
          </div>
        <% } %>

        <% if (album.notes) { %>
          <div class="notes">
            <h2>Notes</h2>
            <p><%= album.notes %></p>
          </div>
        <% } %>

        <div class="actions">
          <a href="/albums/<%= album.id %>/edit" class="btn">Edit</a>
          <form action="/albums/<%= album.id %>?_method=DELETE" method="post"
                onsubmit="return confirm('Delete this record?');" style="display:inline">
            <button type="submit" class="btn btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </article>
  </main>

  <%- include('partials/footer') %>
  <script src="/price-chart.js" defer></script>
</body>
</html>
