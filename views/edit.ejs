<!DOCTYPE html>
<html lang="en">
<head>
  <% const pageTitle = 'Edit ' + album.title; %>
  <%- include('partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container narrow">
    <p class="muted small back"><a href="/albums/<%= album.id %>">← Back to record</a></p>
    <h1 class="form-title">Edit Record</h1>

    <% if (errors.length) { %>
      <ul class="errors">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    <% } %>

    <% if (discogsEnabled) { %>
      <section class="discogs">
        <p class="eyebrow">Search Discogs <% if (album.discogs_release_id) { %><span class="muted small">· linked to release #<%= album.discogs_release_id %></span><% } %></p>
        <div class="discogs-search">
          <input type="search" id="discogs-q" placeholder="Album, artist, barcode…" autocomplete="off" />
          <span class="discogs-status" id="discogs-status"></span>
        </div>
        <ul class="discogs-results" id="discogs-results" hidden></ul>
      </section>
    <% } %>

    <form action="/albums/<%= album.id %>?_method=PUT" method="post" enctype="multipart/form-data" class="form" id="album-form">
      <label>
        <span>Title <em>*</em></span>
        <input type="text" name="title" required value="<%= album.title %>" />
      </label>
      <label>
        <span>Artist <em>*</em></span>
        <input type="text" name="artist" required value="<%= album.artist %>" />
      </label>
      <div class="row">
        <label>
          <span>Year</span>
          <input type="number" name="year" min="1900" max="2100" value="<%= album.year || '' %>" />
        </label>
        <label>
          <span>Genre</span>
          <input type="text" name="genre" value="<%= album.genre || '' %>" />
        </label>
      </div>
      <label>
        <span>Label</span>
        <input type="text" name="label" value="<%= album.label || '' %>" />
      </label>
      <label>
        <span>Notes</span>
        <textarea name="notes" rows="4"><%= album.notes || '' %></textarea>
      </label>

      <div class="row">
        <label>
          <span>Purchase price <em class="muted">(KRW)</em></span>
          <input type="text" inputmode="numeric" name="purchase_price" placeholder="e.g. 32000" value="<%= album.purchase_price || '' %>" />
        </label>
        <label>
          <span>Purchase date</span>
          <input type="date" name="purchase_date" value="<%= album.purchase_date || '' %>" />
        </label>
      </div>

      <input type="hidden" name="cover_url" id="cover_url" value="" />
      <input type="hidden" name="discogs_release_id" id="discogs_release_id" value="<%= album.discogs_release_id || '' %>" />
      <div class="cover-preview" id="cover-preview" hidden>
        <img id="cover-preview-img" alt="" />
        <div>
          <p class="muted small" style="margin:0">Cover from Discogs</p>
          <button type="button" class="btn btn-ghost btn-tiny" id="cover-clear">Remove</button>
        </div>
      </div>

      <% if (album.cover_mime) { %>
        <div class="current-cover">
          <img src="/albums/<%= album.id %>/cover?v=<%= album.cover_version || 1 %>" alt="Current cover" />
          <label class="inline-check">
            <input type="checkbox" name="remove_cover" value="1" />
            <span>Remove current cover</span>
          </label>
        </div>
      <% } %>

      <label class="file">
        <span>Replace cover image <em class="muted">(optional, max 5MB)</em></span>
        <input type="file" name="cover" accept="image/*" />
      </label>

      <div class="actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/albums/<%= album.id %>" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </main>

  <%- include('partials/footer') %>

  <% if (discogsEnabled) { %>
  <script src="/discogs-search.js" defer></script>
  <% } %>
</body>
</html>
