<!DOCTYPE html>
<html lang="en">
<head>
  <% const pageTitle = 'Collection'; %>
  <%- include('partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="home-layout container">
    <section class="turntable-stage">
      <div class="turntable" id="turntable">
        <div class="plinth">
          <div class="platter">
            <div class="lp" id="lp" data-state="idle">
              <div class="lp-grooves"></div>
              <div class="lp-label">
                <img id="lp-label-img" alt="" />
              </div>
              <div class="lp-spindle"></div>
            </div>
          </div>
          <div class="tonearm" id="tonearm">
            <div class="tonearm-base"></div>
            <div class="tonearm-arm">
              <div class="tonearm-head"></div>
            </div>
          </div>
          <button type="button" class="tt-play" id="tt-play" aria-label="Play" disabled>
            <span class="tt-play-icon" aria-hidden="true">▶</span>
          </button>
        </div>
        <div class="now-playing" id="now-playing" data-state="idle">
          <p class="np-eyebrow">Now playing</p>
          <p class="np-title" id="np-title">Pick a record from the list.</p>
          <p class="np-artist muted small" id="np-artist"></p>
          <p class="np-source muted small" id="np-source"></p>
        </div>
      </div>
      <audio id="tt-audio" preload="none"></audio>
    </section>

    <button type="button" class="sheet-toggle" id="sheet-toggle" aria-controls="sheet" aria-expanded="false">
      <span>Collection · <%= albums.length %></span>
    </button>

    <aside class="sheet" id="sheet" aria-label="Collection">
      <header class="sheet-head">
        <h2 class="sheet-title">
          <%= status === 'wishlist' ? 'Wishlist' : 'Collection' %>
          <span class="sheet-count">(<%= albums.length %>)</span>
        </h2>
        <div class="sheet-head-actions">
          <button type="button" class="view-toggle" id="view-toggle" data-current="list" aria-label="Switch to grid view" aria-pressed="false">
            <svg class="view-toggle-icon" data-view="list" viewBox="0 0 20 20" width="18" height="18" aria-hidden="true">
              <rect x="2" y="3.5" width="16" height="2" rx="0.5" />
              <rect x="2" y="9" width="16" height="2" rx="0.5" />
              <rect x="2" y="14.5" width="16" height="2" rx="0.5" />
            </svg>
            <svg class="view-toggle-icon" data-view="grid" viewBox="0 0 20 20" width="18" height="18" aria-hidden="true">
              <rect x="2" y="2" width="7" height="7" rx="0.5" />
              <rect x="11" y="2" width="7" height="7" rx="0.5" />
              <rect x="2" y="11" width="7" height="7" rx="0.5" />
              <rect x="11" y="11" width="7" height="7" rx="0.5" />
            </svg>
          </button>
          <button type="button" class="sheet-close" id="sheet-close" aria-label="Close list">×</button>
        </div>
      </header>
      <div class="sheet-status-row" data-search-open="<%= q ? 'true' : 'false' %>">
        <nav class="sheet-status" aria-label="Status">
          <% const statusOptions = [
            { key: 'owned', label: 'Owned', count: countsByStatus.owned },
            { key: 'wishlist', label: 'Wishlist', count: countsByStatus.wishlist },
          ]; %>
          <% statusOptions.forEach(o => {
               const params = new URLSearchParams();
               if (q) params.set('q', q);
               if (sort !== 'recent') params.set('sort', sort);
               if (o.key !== 'owned') params.set('status', o.key);
               const href = '/' + (params.toString() ? '?' + params.toString() : '');
          %>
            <a href="<%= href %>" class="sheet-status-btn<%= status === o.key ? ' active' : '' %>">
              <%= o.label %><span class="sheet-status-count"><%= o.count %></span>
            </a>
          <% }) %>
        </nav>
        <button type="button" class="search-icon-btn<%= q ? ' active' : '' %>" id="search-toggle" aria-label="Search" aria-expanded="<%= q ? 'true' : 'false' %>" aria-controls="sheet-search-form">
          <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="8.5" cy="8.5" r="5.5" />
            <line x1="12.7" y1="12.7" x2="17" y2="17" />
          </svg>
        </button>
        <form class="sheet-search-inline" id="sheet-search-form" action="/" method="get" role="search">
          <svg class="sheet-search-glyph" viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="8.5" cy="8.5" r="5.5" />
            <line x1="12.7" y1="12.7" x2="17" y2="17" />
          </svg>
          <input type="search" name="q" value="<%= q %>" placeholder="Search title, artist, label…" />
          <input type="hidden" name="sort" value="<%= sort %>" />
          <% if (status !== 'owned') { %><input type="hidden" name="status" value="<%= status %>" /><% } %>
          <button type="button" class="sheet-search-close" id="search-close" aria-label="Close search">×</button>
        </form>
      </div>
      <nav class="sheet-sort" aria-label="Sort">
        <% const sortOptions = [
          { key: 'recent', label: '최신순' },
          { key: 'alpha', label: '가나다순' },
          { key: 'roi', label: '수익률순' },
          { key: 'price', label: '시세순' },
        ]; %>
        <% sortOptions.forEach(o => {
             const params = new URLSearchParams();
             if (q) params.set('q', q);
             if (o.key !== 'recent') params.set('sort', o.key);
             if (status !== 'owned') params.set('status', status);
             const href = '/' + (params.toString() ? '?' + params.toString() : '');
        %>
          <a href="<%= href %>" class="sheet-sort-btn<%= sort === o.key ? ' active' : '' %>"><%= o.label %></a>
        <% }) %>
      </nav>

      <% if (q) { %>
        <p class="muted small sheet-result-line">
          <%= albums.length %> result<%= albums.length === 1 ? '' : 's' %> · <a href="/">clear</a>
        </p>
      <% } %>

      <% if (albums.length === 0) { %>
        <div class="sheet-empty">
          <p class="muted">No records yet.</p>
          <a href="/albums/new" class="btn">Add the first one</a>
        </div>
      <% } else { %>
        <ul class="sheet-list" id="sheet-list">
          <% albums.forEach(a => { %>
            <li class="sheet-row"
                data-id="<%= a.id %>"
                data-title="<%= a.title %>"
                data-artist="<%= a.artist %>"
                data-cover="/albums/<%= a.id %>/cover?v=<%= a.cover_version || 1 %>">
              <button type="button" class="sheet-play" aria-label="Play <%= a.title %>">
                <img class="sheet-thumb" src="/albums/<%= a.id %>/cover?v=<%= a.cover_version || 1 %>" alt="" loading="lazy" />
                <span class="sheet-play-icon" aria-hidden="true">▶</span>
              </button>
              <a class="sheet-link" href="/albums/<%= a.id %>" aria-label="View <%= a.title %>">
                <div class="sheet-meta">
                  <p class="sheet-row-title"><%= a.title %></p>
                  <p class="sheet-row-sub muted small"><%= a.artist %><% if (a.year) { %> · <%= a.year %><% } %></p>
                </div>
                <span class="sheet-go" aria-hidden="true">›</span>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>

      <footer class="sheet-foot">
        <a href="/stats" class="sheet-foot-link">
          <svg viewBox="0 0 18 18" width="14" height="14" aria-hidden="true">
            <line x1="3" y1="14.5" x2="15" y2="14.5" />
            <line x1="5" y1="14.5" x2="5" y2="9" />
            <line x1="9" y1="14.5" x2="9" y2="5" />
            <line x1="13" y1="14.5" x2="13" y2="7.5" />
          </svg>
          <span>View collection stats</span>
        </a>
      </footer>
    </aside>

    <div class="sheet-backdrop" id="sheet-backdrop" hidden></div>
  </main>

  <%- include('partials/footer') %>
  <script src="/turntable.js" defer></script>
</body>
</html>
